# ─── OpenProject Version ────────────────────────────────────────────────────
OPENPROJECT_VERSION=17

# ─── Security ────────────────────────────────────────────────────────────────
# Generate a strong key with: openssl rand -hex 64
SECRET_KEY_BASE=CHANGE_ME_generate_with_openssl_rand_hex_64

# ─── Application ─────────────────────────────────────────────────────────────
HOST_PORT=9080
OPENPROJECT_HOST_NAME=localhost:9080
OPENPROJECT_HTTPS=false
OPENPROJECT_DEFAULT_LANGUAGE=en

# ─── Database (optional override) ────────────────────────────────────────────
# Solo definir si usas una BD PostgreSQL externa, ej:
# DATABASE_URL=postgresql://user:password@host:5432/openproject

# ─── Email / SMTP (optional) ─────────────────────────────────────────────────
# SMTP_ADDRESS=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
